# Auto-detect text files and normalize line endings
* text=auto

# =========================
# Source Code
# =========================
*.cpp text eol=crlf diff=cpp
*.h text eol=crlf diff=cpp
*.hpp text eol=crlf diff=cpp
*.c text eol=crlf diff=cpp
*.py text eol=lf diff=python
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# =========================
# Documentation / Config
# =========================
*.md text eol=lf
*.txt text eol=crlf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# =========================
# Shell / Scripts
# =========================
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# =========================
# Binary Files
# =========================
*.lib binary
*.a binary
*.dll binary
*.exe binary
*.dp32 binary
*.dp64 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary
